# Azure OpenAI / AI Foundry Configuration
# Copy this file to .env and fill in your values

# Your Azure OpenAI endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=

# Deployment name for your model (e.g., gpt-4o, gpt-4-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version (use a recent version that supports function calling)
AZURE_OPENAI_API_VERSION=2024-06-01
