# Azure OpenAI (required for migration planning)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# MIGRATION_AGENT_TEMPERATURE=0.3

# Local dev: DefaultAzureCredential (az login). Non-local: set MANAGED_IDENTITY_CLIENT_ID
ENVIRONMENT=local

# CORS (frontend dev server)
ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# AWS (optional — required only for the AWS Resources tab)
# Use any boto3-compatible credential source:
#   1) Named profile (recommended for local dev)
# AWS_PROFILE=default
#   2) Static keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# Default region used when the UI does not override it
AWS_DEFAULT_REGION=us-east-1
