# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_TEXT_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME_ITEMS=articles-processed-index
AZURE_SEARCH_INDEX_NAME_PREFERENCES=customer-preferences-index
AZURE_SEARCH_INDEX_NAME_ITEM_DETECTION=item-detection-index
AZURE_SEARCH_SEMANTIC_CONFIGURATION_NAME=my-semantic-config-default
AZURE_SEARCH_FILTER_MISSING_IMAGES=true

# Azure Storage for Images
AZURE_STORAGE_IMAGES_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_IMAGES_CONTAINER_NAME=hm-images
AZURE_STORAGE_IMAGES_SAS_TOKEN=your-sas-token
# Optional: Local images path (if available, skips Azure Blob)
# AZURE_STORAGE_IMAGES_LOCAL_IMAGES_PATH=/path/to/local/HandM

# Data Paths for Recommender Models
DATA_RAW_DATA_PATH=/path/to/raw/data
DATA_PROCESSED_DATA_PATH=/path/to/processed/data
DATA_RECOMMENDER_MODELS_PATH=/path/to/recommender/models
# Optional: For cloud storage
# DATA_STORAGE_ACCOUNT_NAME=your-storage-account
# DATA_RECOMMENDER_MODELS_CONTAINER=output

# Ranking Configuration
RANKING_SEARCH_WEIGHT=0.9
RANKING_RS_WEIGHT=0.1
RANKING_APPLY_RERANK=true
RANKING_TWO_STAGE_APPLY_RS_RERANK=true

# Application Settings
APPLICATION_SETTINGS_SKIP_MANAGED_IDENTITY_AUTH=false
