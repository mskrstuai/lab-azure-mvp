# Promotion Planning - Copy to .env and fill in

# Backend API port (Executor uses 8000)
# Backend runs on 8001

# Run Analysis - Azure OpenAI (required for Run Analysis tab)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Executor (sandboxed Python for agent)
EXECUTOR_URL=http://localhost:8000
EXECUTOR_USERNAME=executor
EXECUTOR_PASSWORD=executor-secret

# Optional
ENVIRONMENT=local
RECURSION_LIMIT=20
